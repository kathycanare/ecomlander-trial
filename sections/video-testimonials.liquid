{%- doc -%}
  "Real Change for Real People" style customer video testimonial grid/carousel. Reuses the
  theme's stock slideshow snippet (same one powering sections/carousel.liquid) for responsive
  columns, swipe/scroll behavior, and arrow + dot navigation, so it matches the rest of the
  theme's carousels rather than introducing new interaction patterns.
{%- enddoc -%}

{%- liquid
  assign slide_count = section.blocks.size
  assign show_arrows = false
  if section.settings.icons_style != 'none'
    assign show_arrows = true
  endif

  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif

  if section.settings.section_width == 'page-width'
    assign slideshow_gutters = 'start end'
    assign gutter_style = '--gutter-slide-width: var(--util-page-margin-offset);'
  else
    assign slideshow_gutters = null
    assign gutter_style = '--gutter-slide-width: 0px;'
  endif
-%}

<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="
    section
    section--{{ section.settings.section_width }}
    {% if section.settings.background_color != blank %}color-custom-{{ section.id }}{% endif %}
    section-video-testimonials
    spacing-style
  "
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="video-testimonials-section"
>
  {%- if section.settings.heading != blank -%}
    <div class="video-testimonials__header">
      <p class="video-testimonials__heading {{ section.settings.heading_preset }}">{{ section.settings.heading }}</p>
    </div>
  {%- endif -%}

  {%- capture slides_content -%}
    {% content_for 'blocks' %}
  {%- endcapture -%}

  {% capture slideshow_style %}
    {{ gutter_style }}
    --carousel-columns: {{ section.settings.columns }};
    --carousel-mobile-columns: {{ section.settings.mobile_columns }};
    {% render 'gap-style', value: section.settings.columns_gap, name: 'carousel-gap' %}
  {% endcapture %}

  <div class="force-full-width">
    {% render 'slideshow',
      class: 'video-testimonials__slideshow',
      style: slideshow_style,
      slides: slides_content,
      show_arrows: show_arrows,
      icon_style: section.settings.icons_style,
      icon_shape: section.settings.icons_shape,
      auto_hide_controls: false,
      infinite: false,
      initial_slide: 0,
      slide_count: slide_count,
      slideshow_gutters: slideshow_gutters
    %}
  </div>
</div>

{% stylesheet %}
  .video-testimonials__header {
    text-align: center;
    margin-bottom: var(--margin-lg, 1.5rem);
  }

  .video-testimonials__heading {
    margin: 0;
  }

  .video-testimonials__slideshow slideshow-slides {
    --slideshow-gap: var(--carousel-gap);
  }

  .video-testimonials__slideshow slideshow-slides > .video-testimonial {
    flex: 0 0 auto;
    width: calc(
      (100% - (var(--carousel-gap, 12px) * (var(--carousel-mobile-columns, 2) - 1)) - var(--peek-next-slide-size, 0px)) /
        var(--carousel-mobile-columns, 2)
    );
  }

  @media screen and (min-width: 750px) {
    .video-testimonials__slideshow slideshow-slides > .video-testimonial {
      width: calc(
        (100% - (var(--carousel-gap, 12px) * (var(--carousel-columns, 3) - 1)) - var(--peek-next-slide-size, 0px)) /
          var(--carousel-columns, 3)
      );
    }
  }

  .video-testimonials__slideshow .slideshow-control[disabled] {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video testimonials",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "_video-testimonial-card"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Change for Real People"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Heading size",
      "options": [
        { "value": "h4", "label": "Small" },
        { "value": "h3", "label": "Medium" },
        { "value": "h2", "label": "Large" }
      ],
      "default": "h3"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Gap",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "placeholder": "Default"
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "Icon",
      "options": [
        { "value": "arrow", "label": "Arrows" },
        { "value": "chevron", "label": "Chevrons" },
        { "value": "none", "label": "None" }
      ],
      "default": "arrow"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "Icon background",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle",
      "visible_if": "{{ section.settings.icons_style != 'none' }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Video testimonials",
      "category": "Storytelling",
      "settings": {
        "columns": 3,
        "mobile_columns": "1",
        "columns_gap": 12,
        "padding-block-start": 48,
        "padding-block-end": 48
      },
      "blocks": {
        "video_1": {
          "type": "_video-testimonial-card"
        },
        "video_2": {
          "type": "_video-testimonial-card"
        },
        "video_3": {
          "type": "_video-testimonial-card"
        }
      },
      "block_order": ["video_1", "video_2", "video_3"]
    }
  ]
}
{% endschema %}
