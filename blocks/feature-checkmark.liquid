{%- doc -%}
  A single checkmark + text item, meant to be repeated inside a "group" block (row direction,
  wrapped) to build a feature checklist like "Ease everyday stiffness / Improve daily mobility".
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
-%}

<div
  class="feature-checkmark spacing-style"
  style="
    {% render 'spacing-style', settings: block_settings %}
    --feature-checkmark-color: {{ block_settings.checkmark_color }};
  "
  {{ block.shopify_attributes }}
>
  <span class="feature-checkmark__icon">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
      <path fill="{{ block_settings.badge_color | default: '#1a7a5e' }}" fill-rule="evenodd" clip-rule="evenodd" d="M12 0l2.09 1.86 2.72-.72.99 2.63 2.72.72-.16 2.81 2.27 1.65-1.28 2.51 1.28 2.51-2.27 1.65.16 2.81-2.72.72-.99 2.63-2.72-.72L12 24l-2.09-1.86-2.72.72-.99-2.63-2.72-.72.16-2.81L1.37 14.28l1.28-2.51-1.28-2.51 2.27-1.65-.16-2.81 2.72-.72.99-2.63 2.72.72L12 0z"/>
      <path fill="#ffffff" d="M10.68 15.93l-3.24-3.24 1.36-1.36 1.88 1.88 4.62-4.62 1.36 1.36z"/>
    </svg>
  </span>
  {%- if block_settings.text != blank -%}
    <span class="feature-checkmark__text">{{ block_settings.text }}</span>
  {%- endif -%}
</div>

{% stylesheet %}
  /* The parent "group" block has no built-in wrap setting (its flex container always renders
     --flex-wrap: nowrap inline); scope a wrap override to groups that actually contain
     feature-checkmark items so the 2-up grid works without a global override. */
  .group-block-content:has(> .feature-checkmark) {
    flex-wrap: wrap;
  }

  .feature-checkmark {
    display: flex;
    align-items: center;
    gap: var(--gap-2xs, 0.5rem);
    flex: 1 1 45%;
    min-width: 0;
  }

  .feature-checkmark__icon,
  .feature-checkmark__icon svg {
    width: 26px;
    height: 26px;
    flex-shrink: 0;
  }

  .feature-checkmark__text {
    font-size: var(--font-paragraph--size);
    line-height: 1.3;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Feature checkmark",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Ease everyday stiffness"
    },
    {
      "type": "color",
      "id": "checkmark_color",
      "label": "Checkmark color",
      "default": "#0F3D2E"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Verified badge color",
      "default": "#1a7a5e"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Feature checkmark",
      "category": "Product"
    }
  ]
}
{% endschema %}
