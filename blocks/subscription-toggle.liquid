{%- doc -%}
  A "subscribe & save" checkbox. Functional only if the product has a subscription selling
  plan set up in Shopify Admin (e.g. via the Shopify Subscriptions app) — checking it adds the
  product to the cart on that selling plan, letting Shopify apply the real subscription
  discount at checkout. If no selling plan exists yet, the checkbox renders disabled.
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
  assign product = closest.product
  assign selling_plan_id = ''
  if product.selling_plan_groups.size > 0
    assign first_group = product.selling_plan_groups.first
    assign selling_plan_id = first_group.selling_plans.first.id
  endif
-%}

<script
  src="{{ 'subscription-toggle.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<subscription-toggle-component
  class="subscription-toggle spacing-style"
  style="
    {% render 'spacing-style', settings: block_settings %}
    --subscription-toggle-background: {{ block_settings.background_color }};
    --subscription-toggle-border: {{ block_settings.border_color }};
    {% if block_settings.heading_color != blank %}--subscription-toggle-heading-color: {{ block_settings.heading_color }};{% endif %}
    {% if block_settings.description_color != blank %}--subscription-toggle-description-color: {{ block_settings.description_color }};{% endif %}
    {% if block_settings.check_color != blank %}--subscription-toggle-check-color: {{ block_settings.check_color }};{% endif %}
  "
  data-selling-plan-id="{{ selling_plan_id }}"
  {{ block.shopify_attributes }}
>
  {% render 'checkbox',
    id: 'SubscriptionToggle-' | append: block.id,
    name: 'subscription-toggle-opt-in',
    value: '1',
    label: '',
    checked: block_settings.default_checked,
    disabled: false
  %}
  <div class="subscription-toggle__text">
    {%- if block_settings.label != blank -%}
      <label class="subscription-toggle__heading" for="SubscriptionToggle-{{ block.id }}">{{ block_settings.label }}</label>
    {%- endif -%}
    {%- if block_settings.description != blank -%}
      <p class="subscription-toggle__description">{{ block_settings.description }}</p>
    {%- endif -%}
  </div>
</subscription-toggle-component>

{% stylesheet %}
.subscription-toggle {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 0.6rem;
    background: var(--subscription-toggle-background, transparent);
    border: 2.5px dashed var(--subscription-toggle-border, var(--color-border));
    border-radius: 10px;
    padding: var(--padding-md);
  }

  .subscription-toggle__text {
    display: flex;
    flex-direction: column;
  }

  .subscription-toggle__heading {
    font-weight: 700;
    font-size: var(--font-size--md, 1.05rem);
    color: var(--subscription-toggle-heading-color, inherit);
    cursor: pointer;
  }

  .subscription-toggle .checkbox {
    display: flex;
    align-items: center;
  }

  .subscription-toggle .checkbox {
    flex-shrink: 0;
  }

  .subscription-toggle .checkbox {
    position: relative;
    flex-shrink: 0;
  }

  .subscription-toggle .checkbox__label {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px !important;
    min-width: 26px !important;
    max-width: 26px !important;
    height: 26px !important;
    min-height: 26px !important;
    max-height: 26px !important;
    aspect-ratio: 1 / 1 !important;
    box-sizing: border-box !important;
    border-radius: 8px;
    border: 2px solid var(--subscription-toggle-check-color, #0F3D2E);
    background: transparent;
    cursor: pointer;
    padding: 0 !important;
    flex-shrink: 0 !important;
  }

  .subscription-toggle .checkbox__input:checked + .checkbox__label {
    background: var(--subscription-toggle-check-color, #0F3D2E);
  }

  .subscription-toggle .checkbox__label svg {
    display: none;
  }

  .subscription-toggle .checkbox__input:checked + .checkbox__label::after {
    content: '';
    position: absolute;
    left: 9px;
    top: 5px;
    width: 6px;
    height: 11px;
    border: solid #ffffff;
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }

  .subscription-toggle__description {
    margin: 0;
    font-size: var(--font-size--sm, 0.8rem);
    color: var(--subscription-toggle-description-color, inherit);
  }
{% endstylesheet %}

