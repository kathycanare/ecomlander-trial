{%- doc -%}
  "Real Change for Real People" style customer video testimonial carousel, scoped to the
  width of whatever column it's placed in (e.g. inside "_product-details", matching the Figma
  design where this sits under the trust/delivery rows in the product info column — not as a
  full-width section). Reuses the theme's stock slideshow snippet for the same swipe/arrow/dot
  navigation as the rest of the theme's carousels.
{%- enddoc -%}

{%- liquid
  assign block_settings = block.settings
  assign slide_count = block.blocks.size
  assign show_arrows = false
  if block_settings.icons_style != 'none'
    assign show_arrows = true
  endif
-%}

<div
  class="video-testimonials spacing-style"
  style="{% render 'spacing-style', settings: block_settings %}"
  {{ block.shopify_attributes }}
>
  {%- if block_settings.heading != blank -%}
    <p class="video-testimonials__heading {{ block_settings.heading_preset }}">{{ block_settings.heading }}</p>
  {%- endif -%}

  {%- capture slides_content -%}
    {% content_for 'blocks' %}
  {%- endcapture -%}

  {% capture slideshow_style %}
    --carousel-columns: {{ block_settings.columns }};
    --carousel-mobile-columns: {{ block_settings.mobile_columns }};
    {% render 'gap-style', value: block_settings.columns_gap, name: 'carousel-gap' %}
  {% endcapture %}

  {% render 'slideshow',
    class: 'video-testimonials__slideshow',
    style: slideshow_style,
    slides: slides_content,
    show_arrows: show_arrows,
    icon_style: block_settings.icons_style,
    icon_shape: block_settings.icons_shape,
    auto_hide_controls: false,
    infinite: false,
    initial_slide: 0,
    slide_count: slide_count
  %}
</div>

{% stylesheet %}
  .video-testimonials__heading {
    margin: 0 0 var(--margin-md, 1rem);
    font-weight: 600;
  }

  .video-testimonials__slideshow slideshow-slides {
    --slideshow-gap: var(--carousel-gap);
  }

  .video-testimonials__slideshow slideshow-slides > .video-testimonial {
    flex: 0 0 auto;
    width: calc(
      (100% - (var(--carousel-gap, 12px) * (var(--carousel-mobile-columns, 3) - 1))) /
        var(--carousel-mobile-columns, 3)
    );
  }

  .video-testimonials__slideshow .slideshow-control[disabled] {
    display: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Video testimonials",
  "tag": null,
  "blocks": [
    {
      "type": "_video-testimonial-card"
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Change for Real People"
    },
    {
      "type": "select",
      "id": "heading_preset",
      "label": "Heading size",
      "options": [
        { "value": "h6", "label": "Small" },
        { "value": "h5", "label": "Medium" },
        { "value": "h4", "label": "Large" }
      ],
      "default": "h5"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Desktop columns",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "columns_gap",
      "label": "Gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Navigation"
    },
    {
      "type": "select",
      "id": "icons_style",
      "label": "Icon",
      "options": [
        { "value": "arrow", "label": "Arrows" },
        { "value": "chevron", "label": "Chevrons" },
        { "value": "none", "label": "None" }
      ],
      "default": "arrow"
    },
    {
      "type": "select",
      "id": "icons_shape",
      "label": "Icon background",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "circle", "label": "Circle" },
        { "value": "square", "label": "Square" }
      ],
      "default": "circle",
      "visible_if": "{{ block.settings.icons_style != 'none' }}"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "Left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "Right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Video testimonials",
      "category": "Product",
      "blocks": {
        "video_1": { "type": "_video-testimonial-card" },
        "video_2": { "type": "_video-testimonial-card" },
        "video_3": { "type": "_video-testimonial-card" }
      },
      "block_order": ["video_1", "video_2", "video_3"]
    }
  ]
}
{% endschema %}
